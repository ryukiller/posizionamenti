{
  "name": "posizionamenti",
  "version": "0.3.7",
  "description": "App desktop cross-platform (macOS e Windows) per verificare le posizioni sui motori di ricerca (Google). L'app scarica dalla webapp la lista di clienti/domini/keyword, esegue ricerche in browser visibile con Playwright, rileva la posizione del dominio target nella SERP, salva screenshot annotati e invia i risultati all'API backend.",
  "main": "out/main/index.js",
  "scripts": {
    "build:engine": "tsc",
    "dev": "npm run build:engine && electron-vite dev",
    "build": "npm run build:engine && electron-vite build",
    "preview": "electron-vite preview",
    "start": "npm run dev",
    "dev:cli": "ts-node src/cli.ts run-once",
    "dev:cli:loop": "ts-node src/cli.ts run-loop",
    "electron:dev": "npm run dev",
    "electron:build": "npm run build && electron-builder --publish=never",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "form-data": "^4.0.5",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/yargs": "^17.0.35",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.swi.posizionamenti",
    "productName": "Posizionamenti",
    "files": [
      "out/**/*",
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ryukiller",
        "repo": "posizionamenti"
      }
    ]
  }
}
